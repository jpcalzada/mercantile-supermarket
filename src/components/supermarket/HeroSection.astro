---
import { Image } from 'astro:assets';
import { products } from '../../lib/products';

const heroProduct = products.find((p) => p.hero)!;
---

<section class="min-h-[90vh] flex items-center px-6 lg:px-12 bg-bone">
  <div class="w-full max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center pt-28 pb-16 lg:pt-0 lg:pb-0">

    <!-- Copy -->
    <div class="space-y-8 z-10">
      <div class="animate-fade-up delay-100">
        <p class="text-[11px] tracking-[0.2em] uppercase text-obsidian-muted mb-6">Curated Grocery</p>
        <h1 class="text-5xl sm:text-6xl xl:text-7xl font-bold tracking-tighter leading-[0.95] text-obsidian">
          The<br/>Mercantile
        </h1>
        <p class="text-obsidian-muted text-[15px] mt-5 max-w-sm leading-relaxed font-light">
          Ingredients with provenance. A supermarket for people who read the label.
        </p>
      </div>

      <div class="w-12 hairline-h animate-fade-up delay-200"></div>

      <div class="animate-fade-up delay-300">
        <p class="text-[11px] tracking-[0.15em] uppercase text-obsidian-muted">{heroProduct.label} / {heroProduct.name} / {heroProduct.size}</p>
        <p class="text-[15px] text-obsidian-light leading-relaxed mt-3 max-w-md font-light">
          {heroProduct.description}
        </p>
      </div>

      <div class="flex items-center gap-6 animate-fade-up delay-400">
        <span class="font-mono text-xl text-obsidian">${heroProduct.price.toFixed(2)}</span>
        <button
          data-add-hero
          data-product-id={heroProduct.id}
          data-product-name={heroProduct.name}
          data-product-price={heroProduct.price}
          data-product-unit={heroProduct.size}
          data-product-image={heroProduct.image}
          class="btn-primary px-7 py-3 text-[11px] tracking-[0.12em] uppercase"
        >
          Add to Curation
        </button>
        <a
          href={`/supermarket/${heroProduct.id}`}
          class="text-[11px] tracking-[0.12em] uppercase text-obsidian-muted hover:text-obsidian transition-colors"
        >
          View Details
        </a>
      </div>
    </div>

    <!-- Image -->
    <div class="animate-fade-up delay-300">
      <a href={`/supermarket/${heroProduct.id}`} class="block">
        <div class="aspect-[3/4] w-full max-w-md mx-auto rounded-card overflow-hidden bg-bone-dark">
          <Image
            src={heroProduct.image}
            alt={heroProduct.name}
            width={600}
            height={800}
            class="w-full h-full object-cover product-image"
            loading="eager"
            style={`view-transition-name: product-${heroProduct.id}`}
          />
        </div>
      </a>
    </div>
  </div>
</section>

<script>
  import { addToCart } from '../../lib/cartStore';

  function showToast(message: string) {
    const toast = document.getElementById('toast');
    if (!toast) return;
    toast.textContent = message;
    toast.classList.add('visible');
    setTimeout(() => toast.classList.remove('visible'), 2500);
  }

  document.querySelector('[data-add-hero]')?.addEventListener('click', (e) => {
    const btn = e.currentTarget as HTMLElement;
    addToCart({
      id: btn.dataset.productId!,
      name: btn.dataset.productName!,
      price: parseFloat(btn.dataset.productPrice!),
      unit: btn.dataset.productUnit!,
      image: btn.dataset.productImage!,
    });
    showToast('Added to Curation');
  });
</script>
