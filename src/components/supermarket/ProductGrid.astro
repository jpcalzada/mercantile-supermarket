---
import { products, collections } from '../../lib/products';

const nonHeroProducts = products.filter((p) => !p.hero);
const grouped = Object.entries(collections).map(([slug, col]) => ({
  slug,
  ...col,
  items: nonHeroProducts.filter((p) =>
    (col.categories as readonly string[]).includes(p.category)
  ),
}));
---

{grouped.map((collection) => collection.items.length > 0 && (
  <section id={collection.slug} class="px-6 lg:px-16 py-20">
    <!-- Collection Header -->
    <div class="max-w-6xl mx-auto mb-12">
      <h3 class="font-display text-3xl lg:text-4xl text-charcoal">
        {collection.name}
      </h3>
      <p class="text-sm text-charcoal-muted mt-2">
        {collection.tagline}
      </p>
    </div>

    <!-- Product Grid -->
    <div class="max-w-6xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {collection.items.map((product) => (
        <div class="product-card overflow-hidden group cursor-pointer">
          <!-- Image -->
          <div class="aspect-[4/3] w-full overflow-hidden rounded-t-[24px]">
            <img
              src={product.image}
              alt={product.name}
              class="w-full h-full object-cover product-image"
              loading="lazy"
            />
          </div>

          <!-- Info -->
          <div class="p-6 space-y-3">
            <div class="flex items-start justify-between gap-3">
              <h4 class="font-display text-lg text-charcoal group-hover:text-charcoal-light transition-colors duration-300">
                {product.name}
              </h4>
              <span class="font-mono-price text-sm font-semibold text-charcoal whitespace-nowrap mt-0.5">
                ${product.price.toFixed(2)}
              </span>
            </div>

            <p class="text-xs text-charcoal-muted">
              {product.unit}
            </p>

            <p class="text-sm text-charcoal-light leading-relaxed">
              {product.description}
            </p>

            <button
              data-add-product
              data-product-id={product.id}
              data-product-name={product.name}
              data-product-price={product.price}
              data-product-unit={product.unit}
              data-product-image={product.image}
              class="mt-2 btn-outline px-5 py-2 text-xs font-medium w-full"
            >
              Add to Cart
            </button>
          </div>
        </div>
      ))}
    </div>
  </section>
))}

<script>
  import { addToCart } from '../../lib/cartStore';

  document.querySelectorAll('[data-add-product]').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      const el = e.currentTarget as HTMLElement;
      addToCart({
        id: el.dataset.productId!,
        name: el.dataset.productName!,
        price: parseFloat(el.dataset.productPrice!),
        unit: el.dataset.productUnit!,
        image: el.dataset.productImage!,
      });
    });
  });
</script>
