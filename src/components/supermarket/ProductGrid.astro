---
import { Image } from 'astro:assets';
import { products } from '../../lib/products';

const gridProducts = products.filter((p) => !p.hero);
---

<section class="px-6 lg:px-12 py-20">
  <div class="max-w-6xl mx-auto mb-14">
    <h2 class="text-3xl lg:text-4xl font-bold tracking-tighter text-obsidian">All Products</h2>
    <p class="text-sm text-obsidian-muted mt-2 font-light">10 items, each one traceable to source.</p>
  </div>

  <div class="max-w-6xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
    {gridProducts.map((product) => (
      <div class="product-card overflow-hidden group">
        <a href={`/supermarket/${product.id}`} class="block">
          <div class="aspect-[4/3] w-full overflow-hidden rounded-card bg-bone-dark">
            <Image
              src={product.image}
              alt={product.name}
              width={800}
              height={600}
              class="w-full h-full object-cover product-image"
              loading="lazy"
            />
          </div>
        </a>

        <div class="pt-5 pb-2 space-y-2">
          <p class="text-[10px] tracking-[0.15em] uppercase text-obsidian-muted">
            {product.label} / {product.size}
          </p>

          <div class="flex items-baseline justify-between gap-3">
            <a href={`/supermarket/${product.id}`}>
              <h3 class="text-base font-semibold tracking-tight text-obsidian group-hover:text-stone transition-colors duration-500">
                {product.name}
              </h3>
            </a>
            <span class="font-mono text-sm text-obsidian">${product.price.toFixed(2)}</span>
          </div>

          <p class="text-[13px] text-obsidian-muted leading-relaxed font-light line-clamp-2">
            {product.description}
          </p>

          <div class="flex items-center gap-4 pt-2">
            <button
              data-add-product
              data-product-id={product.id}
              data-product-name={product.name}
              data-product-price={product.price}
              data-product-unit={product.size}
              data-product-image={product.image}
              class="text-[10px] tracking-[0.12em] uppercase text-obsidian-muted hover:text-obsidian transition-colors"
            >
              + Add
            </button>
            <a
              href={`/supermarket/${product.id}`}
              class="text-[10px] tracking-[0.12em] uppercase text-obsidian-muted hover:text-obsidian transition-colors"
            >
              Details
            </a>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  import { addToCart } from '../../lib/cartStore';

  function showToast(message: string) {
    const toast = document.getElementById('toast');
    if (!toast) return;
    toast.textContent = message;
    toast.classList.add('visible');
    setTimeout(() => toast.classList.remove('visible'), 2500);
  }

  document.querySelectorAll('[data-add-product]').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      const el = e.currentTarget as HTMLElement;
      addToCart({
        id: el.dataset.productId!,
        name: el.dataset.productName!,
        price: parseFloat(el.dataset.productPrice!),
        unit: el.dataset.productUnit!,
        image: el.dataset.productImage!,
      });
      showToast('Added to Curation');
    });
  });
</script>
