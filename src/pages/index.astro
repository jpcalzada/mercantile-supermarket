---
import { Image } from 'astro:assets';
import '../styles/mercantile.css';
import SensoryNav from '../components/supermarket/SensoryNav.astro';
import MercantileFooter from '../components/supermarket/MercantileFooter.astro';
import { products } from '../lib/products';
import { resolveImage } from '../lib/images';
import tonicbarCover from '../assets/tonicbar-cover.webp';
import pantyCover from '../assets/thepantry-cover.webp';

const produce = products.filter((p) => p.category === 'produce');
const bakery = products.filter((p) => p.category === 'bakery');
const tonicBar = products.filter((p) => p.category === 'juice-bar' && ['vitality-juice', 'matcha-tonic', 'immunity-shot', 'charcoal-cleanse', 'aloe-water'].includes(p.id));
const cafe = products.filter((p) => p.category === 'juice-bar' && ['ethiopian-beans', 'ceremonial-matcha', 'cold-brew', 'oat-latte', 'earl-grey-tea'].includes(p.id));
const pantry = products.filter((p) => p.category === 'pantry');
const deli = products.filter((p) => p.category === 'deli');
const dairyAlt = products.filter((p) => p.category === 'dairy-alt');
const sweetTreats = products.filter((p) => p.category === 'sweet-treats');

const heroBanners = [
  { href: '/garden', image: 'https://images.unsplash.com/photo-1542838132-92c53300491e?auto=format&fit=crop&w=1200&q=80', alt: 'Fresh produce', subtitle: 'Fresh Daily', title: 'The Garden' },
  { href: '/bakery', image: 'https://images.unsplash.com/photo-1509440159596-0249088772ff?auto=format&fit=crop&w=1200&q=80', alt: 'Artisan bakery', subtitle: 'Baked Today', title: 'The Bakery' },
  { href: '/tonic-bar', image: tonicbarCover, alt: 'The Tonic Bar — cold-pressed daily', subtitle: 'Cold-Pressed Daily', title: 'Tonic Bar' },
  { href: '/pantry', image: pantyCover, alt: 'The Pantry — staples and essentials', subtitle: 'Staples & Essentials', title: 'The Pantry' },
];
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
  <meta name="view-transition" content="same-origin" />
  <title>The Mercantile — Curated Grocery</title>
  <meta name="description" content="Ingredients with provenance. A supermarket for people who read the label." />
</head>
<body class="mercantile-page">
  <SensoryNav />

  <main class="main-content pt-[64px]">

    {/* ── HERO BANNER CAROUSEL ── */}
    <section class="px-4 lg:px-6 pt-4">
      <div class="carousel-wrap">
        <div class="carousel-track" id="carousel-hero">
          {heroBanners.map((b) => (
            <a href={b.href} class="hero-banner-card relative aspect-[2/1] overflow-hidden rounded-[12px] bg-surface group flex-shrink-0">
              <Image
                src={b.image}
                alt={b.alt}
                width={1200}
                height={600}
                decoding="async"
                class="w-full h-full object-cover transition-transform duration-600 group-hover:scale-105"
                style="transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);"
                loading="eager"
              />
              <div class="absolute inset-0 flex flex-col items-center justify-center text-center">
                <p class="text-[10px] font-bold tracking-[0.02em] uppercase text-white/70 mb-1">{b.subtitle}</p>
                <h2 class="text-2xl lg:text-4xl tracking-tight text-white">{b.title}</h2>
              </div>
            </a>
          ))}
        </div>
        <button class="carousel-arrow right" data-scroll-target="carousel-hero" aria-label="Scroll right">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>
    </section>

    {/* ── PRODUCE GRID ── */}
    <section id="produce" class="px-4 lg:px-6 pt-4 scroll-reveal">
      <div class="flex items-baseline justify-between mb-4">
        <h3 class="text-[19px] font-black tracking-[0.04em] uppercase text-obsidian">Fresh Produce</h3>
        <a href="/garden" class="text-[9px] font-bold tracking-[0.04em] uppercase text-obsidian-muted hover:text-obsidian transition-colors">View All</a>
      </div>
      <div class="grid grid-cols-3 md:grid-cols-6 gap-4">
        {produce.slice(0, 6).map((product) => (
          <div class="product-card group" data-category={product.category}>
            <a href={`/supermarket/${product.id}`} class="block">
              <div class="card-image-wrap aspect-square w-full">
                <Image src={resolveImage(product.image)} alt={product.name} width={800} height={800} class="w-full h-full object-cover product-image" loading="lazy" />
              </div>
            </a>
            <div class="pt-3">
              <p class="text-[10px] font-bold tracking-[0.02em] uppercase text-obsidian-muted">{product.label}</p>
              <h4 class="text-sm font-bold text-obsidian mt-0.5 leading-tight">{product.name}</h4>
              <div class="flex items-baseline justify-between mt-1">
                <span class="text-sm font-medium text-obsidian">${product.price.toFixed(2)}</span>
                <button data-add-product data-product-id={product.id} data-product-name={product.name} data-product-price={product.price} data-product-unit={product.size} data-product-image={product.image} class="btn-add">+ Add</button>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

