</html>

<script>
  import { addToCart } from '../lib/cartStore';

  function showToast(message: string) {
    const toast = document.getElementById('toast');
    if (!toast) return;
    toast.textContent = message;
    toast.classList.add('visible');
    setTimeout(() => toast.classList.remove('visible'), 2500);
  }

  document.querySelectorAll('[data-add-product]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      addToCart({
        id: el.dataset.productId!,
        name: el.dataset.productName!,
        price: parseFloat(el.dataset.productPrice!),
        unit: el.dataset.productUnit!,
        image: el.dataset.productImage!,
      });
      showToast('Added to bag');
    });
  });

  // Carousel arrow scrolling (hero only now)
  document.querySelectorAll('.carousel-arrow').forEach((arrow) => {
    arrow.addEventListener('click', () => {
      const targetId = (arrow as HTMLElement).dataset.scrollTarget!;
      const track = document.getElementById(targetId);
      if (!track) return;
      const card = track.querySelector('.hero-banner-card') as HTMLElement;
      const scrollAmount = card ? card.offsetWidth + 16 : 460; // 16 = gap
      track.scrollBy({ left: scrollAmount, behavior: 'smooth' });
    });
  });

  // Single observer for both section reveals and product card fade-ups
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        if (entry.target.classList.contains('scroll-reveal')) {
          entry.target.classList.add('revealed');
        } else {
          entry.target.classList.add('visible');
        }
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.scroll-reveal').forEach((el) => observer.observe(el));

  document.querySelectorAll('.product-card').forEach((card, i) => {
    // Stagger within each row (3 cols mobile, 6 cols desktop)
    (card as HTMLElement).style.transitionDelay = `${(i % 6) * 0.08}s`;
    observer.observe(card);
  });
</script>
