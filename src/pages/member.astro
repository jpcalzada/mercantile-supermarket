---
import '../styles/mercantile.css';
import SensoryNav from '../components/supermarket/SensoryNav.astro';
import MercantileFooter from '../components/supermarket/MercantileFooter.astro';

const benefits = [
  { title: 'Free Delivery', desc: 'On all orders over $75', icon: '🚚' },
  { title: 'Early Access', desc: 'Shop new arrivals 48hrs early', icon: '⏰' },
  { title: 'Birthday Reward', desc: '$25 credit on your birthday', icon: '🎂' },
  { title: 'Member Pricing', desc: 'Exclusive pricing on 200+ items', icon: '🏷️' },
  { title: 'Tonic Bar Perks', desc: 'One free cold-press per week', icon: '🥤' },
  { title: 'Sustainability Fund', desc: '1% of spend to local farms', icon: '🌿' },
];

const offers = [
  { label: 'This Week', title: '20% Off All Bakery', code: 'BAKE20', expires: 'Mar 21' },
  { label: 'Member Only', title: 'Free Tonic Bar Smoothie', code: 'TONIC1', expires: 'Mar 31' },
  { label: 'Seasonal', title: '$10 Off Spring Produce Box', code: 'SPRING10', expires: 'Apr 15' },
];
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="view-transition" content="same-origin" />
  <title>Member — The Mercantile</title>
  <meta name="description" content="Your Mercantile membership — rewards, benefits, and exclusive offers." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
</head>
<body class="mercantile-page">
  <SensoryNav />
  <main class="main-content pt-[64px]">
    <section class="px-6 lg:px-12 py-12">
      <div class="max-w-6xl mx-auto">
        <p class="text-[10px] font-bold tracking-[0.1em] uppercase text-obsidian-muted mb-2">Membership</p>
        <h1 class="text-3xl lg:text-4xl font-black tracking-tight uppercase text-obsidian">Your Mercantile</h1>

        <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 mt-10">

          {/* ── LEFT: Rewards / Status ── */}
          <div class="lg:col-span-2 space-y-8">
            <div class="bg-obsidian rounded-[12px] p-8 text-bone">
              <p class="text-[10px] font-bold tracking-[0.1em] uppercase text-bone/60 mb-1">Status</p>
              <h2 class="text-2xl font-black tracking-tight uppercase">Gold Member</h2>
              <div class="mt-6">
                <div class="flex items-baseline justify-between mb-2">
                  <span class="text-[10px] font-bold tracking-[0.1em] uppercase text-bone/60">Points Balance</span>
                  <span class="text-lg font-black">2,450</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="h-full bg-bone rounded-full" style="width: 65%;"></div>
                </div>
                <p class="text-[10px] text-bone/40 mt-2">550 points to Platinum</p>
              </div>
              <div class="grid grid-cols-2 gap-4 mt-6">
                <div>
                  <p class="text-[10px] font-bold tracking-[0.1em] uppercase text-bone/60 mb-1">Member Since</p>
                  <p class="text-sm font-bold">Jan 2024</p>
                </div>
                <div>
                  <p class="text-[10px] font-bold tracking-[0.1em] uppercase text-bone/60 mb-1">Lifetime Spend</p>
                  <p class="text-sm font-bold">$4,280</p>
                </div>
              </div>
            </div>

            <div>
              <p class="text-[10px] font-bold tracking-[0.1em] uppercase text-obsidian-muted mb-4">Recent Activity</p>
              <div class="space-y-3">
                <div class="flex items-center justify-between py-2">
                  <div>
                    <p class="text-sm font-bold text-obsidian">Order #4821</p>
                    <p class="text-[10px] text-obsidian-muted">Mar 10, 2026</p>
                  </div>
                  <span class="text-sm font-medium text-obsidian">+120 pts</span>
                </div>
                <div class="hairline-h"></div>
                <div class="flex items-center justify-between py-2">
                  <div>
                    <p class="text-sm font-bold text-obsidian">Order #4799</p>
                    <p class="text-[10px] text-obsidian-muted">Mar 3, 2026</p>
                  </div>
                  <span class="text-sm font-medium text-obsidian">+85 pts</span>
                </div>
                <div class="hairline-h"></div>
                <div class="flex items-center justify-between py-2">
                  <div>
                    <p class="text-sm font-bold text-obsidian">Referral Bonus</p>
                    <p class="text-[10px] text-obsidian-muted">Feb 28, 2026</p>
                  </div>
                  <span class="text-sm font-medium text-obsidian">+500 pts</span>
                </div>
              </div>
            </div>
          </div>

          {/* ── RIGHT: Benefits + Offers ── */}
          <div class="lg:col-span-3 space-y-10">
            <div>
              <p class="text-[10px] font-bold tracking-[0.1em] uppercase text-obsidian-muted mb-4">Member Benefits</p>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {benefits.map((b) => (
                  <div class="bg-surface rounded-[12px] p-6 border border-detail-bg">
                    <span class="text-2xl mb-3 block">{b.icon}</span>
                    <h3 class="text-sm font-black tracking-tight text-obsidian uppercase">{b.title}</h3>
                    <p class="text-sm text-obsidian-muted mt-1">{b.desc}</p>
                  </div>
                ))}
              </div>
            </div>

            <div>
              <p class="text-[10px] font-bold tracking-[0.1em] uppercase text-obsidian-muted mb-4">Current Offers</p>
              <div class="space-y-4">
                {offers.map((o) => (
                  <div class="bg-surface rounded-[12px] p-6 border border-detail-bg flex items-center justify-between">
                    <div>
                      <p class="text-[10px] font-bold tracking-[0.1em] uppercase text-obsidian-muted mb-1">{o.label}</p>
                      <h3 class="text-sm font-black tracking-tight text-obsidian uppercase">{o.title}</h3>
                      <p class="text-[10px] text-obsidian-muted mt-1">Expires {o.expires}</p>
                    </div>
                    <div class="text-right">
                      <span class="inline-block bg-obsidian text-bone text-[10px] font-bold tracking-[0.1em] px-4 py-2 rounded-full uppercase">{o.code}</span>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <MercantileFooter />
</body>
</html>
