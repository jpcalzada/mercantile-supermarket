---
import '../styles/mercantile.css';
import SensoryNav from '../components/supermarket/SensoryNav.astro';
import MercantileFooter from '../components/supermarket/MercantileFooter.astro';
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
  <meta name="view-transition" content="same-origin" />
  <title>Contact Us — The Mercantile</title>
  <meta name="description" content="Get in touch with The Mercantile team." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
</head>
<body class="mercantile-page">
  <SensoryNav />
  <main class="main-content pt-[64px]">
    <section class="px-6 lg:px-12 py-16">
      <div class="max-w-3xl mx-auto">
        <p class="text-[10px] font-bold tracking-[0.1em] uppercase text-obsidian-muted mb-2">Get in Touch</p>
        <h1 class="text-3xl lg:text-4xl font-black tracking-tight uppercase text-obsidian">Contact Us</h1>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 mt-12">
          <div class="space-y-8">
            <div>
              <h2 class="text-sm font-black tracking-[0.1em] uppercase text-obsidian mb-2">General Inquiries</h2>
              <p class="text-sm text-obsidian-muted leading-[1.7]">hello@themercantile.com</p>
              <p class="text-sm text-obsidian-muted leading-[1.7]">(800) 555-MERC</p>
            </div>
            <div>
              <h2 class="text-sm font-black tracking-[0.1em] uppercase text-obsidian mb-2">Catering</h2>
              <p class="text-sm text-obsidian-muted leading-[1.7]">catering@themercantile.com</p>
            </div>
            <div>
              <h2 class="text-sm font-black tracking-[0.1em] uppercase text-obsidian mb-2">Press & Partnerships</h2>
              <p class="text-sm text-obsidian-muted leading-[1.7]">press@themercantile.com</p>
            </div>
            <div>
              <h2 class="text-sm font-black tracking-[0.1em] uppercase text-obsidian mb-2">Careers</h2>
              <p class="text-sm text-obsidian-muted leading-[1.7]">We're always looking for people who care about food as much as we do.</p>
              <p class="text-sm text-obsidian-muted leading-[1.7]">careers@themercantile.com</p>
            </div>
          </div>

          <div>
            <h2 class="text-sm font-black tracking-[0.1em] uppercase text-obsidian mb-4">Send a Message</h2>
            <form class="space-y-4" onsubmit="event.preventDefault()">
              <div>
                <label class="text-[10px] font-bold tracking-[0.1em] uppercase text-obsidian-muted block mb-1">Name</label>
                <input type="text" class="w-full bg-transparent text-sm text-obsidian py-2 outline-none" style="border-bottom: 1px solid rgba(140, 126, 106, 0.2);" />
              </div>
              <div>
                <label class="text-[10px] font-bold tracking-[0.1em] uppercase text-obsidian-muted block mb-1">Email</label>
                <input type="email" class="w-full bg-transparent text-sm text-obsidian py-2 outline-none" style="border-bottom: 1px solid rgba(140, 126, 106, 0.2);" />
              </div>
              <div>
                <label class="text-[10px] font-bold tracking-[0.1em] uppercase text-obsidian-muted block mb-1">Subject</label>
                <input type="text" class="w-full bg-transparent text-sm text-obsidian py-2 outline-none" style="border-bottom: 1px solid rgba(140, 126, 106, 0.2);" />
              </div>
              <div>
                <label class="text-[10px] font-bold tracking-[0.1em] uppercase text-obsidian-muted block mb-1">Message</label>
                <textarea rows="4" class="shopper-notes w-full"></textarea>
              </div>
              <button type="submit" class="btn-primary w-full py-3 text-[11px] font-bold tracking-[0.1em] uppercase text-center mt-4">
                Send Message
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>
  <MercantileFooter />
</body>
</html>
