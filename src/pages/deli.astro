---
import { Image } from 'astro:assets';
import '../styles/mercantile.css';
import BaseHead from '../components/BaseHead.astro';
import SensoryNav from '../components/supermarket/SensoryNav.astro';
import MercantileFooter from '../components/supermarket/MercantileFooter.astro';
import { products } from '../lib/products';
import { resolveImage } from '../lib/images';

const deli = products.filter((p) => p.category === 'deli' || p.category === 'sushi');
---

<html lang="en">
<head>
  <BaseHead 
    title="The Deli — The Mercantile" 
    description="Charcuterie, cheese, and cured goods. The Deli at The Mercantile."
    enableViewTransitions={true}
    includeGoogleFonts={true}
  />
</head>
<body class="mercantile-page">
  <SensoryNav />
  <main class="main-content pt-[64px]">
    <section class="px-4 lg:px-6 pt-4">
      <div class="relative aspect-[3/1] overflow-hidden rounded-[12px] bg-surface mb-8">
        <Image
          src="https://images.unsplash.com/photo-1528750997573-59b89d56f4f7?auto=format&fit=crop&w=1600&q=80"
          alt="The Deli"
          width={1600} height={533} decoding="async" class="w-full h-full object-cover"
          loading="eager"
        />
        <div class="absolute inset-0 flex flex-col items-center justify-center text-center">
          <p class="text-[10px] tracking-[0.02em] uppercase text-white/70 mb-1">Cured & Crafted</p>
          <h1 class="category-page-title">The Deli</h1>
        </div>
      </div>
    </section>

    <section class="px-4 lg:px-6 pb-10">
      <div class="grid grid-cols-3 md:grid-cols-6 gap-4">
        {deli.map((product) => (
          <div class="product-card group" data-category={product.category}>
            <a href={`/supermarket/${product.id}`} class="block">
              <div class="card-image-wrap aspect-square w-full">
                <Image src={resolveImage(product.image)} alt={product.name} width={800} height={800} class="w-full h-full object-cover product-image" loading="lazy" />
              </div>
            </a>
            <div class="pt-3">
              <p class="text-[10px] font-bold tracking-[0.02em] uppercase text-obsidian-muted">{product.label}</p>
              <h4 class="text-sm font-bold text-obsidian mt-0.5 leading-tight">{product.name}</h4>
              <div class="flex items-baseline justify-between mt-1">
                <span class="text-sm font-medium text-obsidian">${product.price.toFixed(2)}</span>
                <button data-add-product data-product-id={product.id} data-product-name={product.name} data-product-price={product.price} data-product-unit={product.size} data-product-image={product.image} class="btn-add">+ Add</button>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>
  </main>
  <MercantileFooter />
</body>
</html>

<script>
  import { addToCart } from '../lib/cartStore';

  function showToast(message: string) {
    const toast = document.getElementById('toast');
    if (!toast) return;
    toast.textContent = message;
    toast.classList.add('visible');
    setTimeout(() => toast.classList.remove('visible'), 2500);
  }

  document.querySelectorAll('[data-add-product]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      addToCart({
        id: el.dataset.productId!,
        name: el.dataset.productName!,
        price: parseFloat(el.dataset.productPrice!),
        unit: el.dataset.productUnit!,
        image: el.dataset.productImage!,
      });
      showToast('Added to bag');
    });
  });

  // Product card fade-in on scroll
  const cards = document.querySelectorAll('.product-card');
  const cardObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        cardObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  cards.forEach((card, i) => {
    (card as HTMLElement).style.transitionDelay = `${i % 6 * 0.08}s`;
    cardObserver.observe(card);
  });
</script>
