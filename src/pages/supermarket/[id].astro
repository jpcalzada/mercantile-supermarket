---
import { Image } from 'astro:assets';
import '../../styles/mercantile.css';
import SensoryNav from '../../components/supermarket/SensoryNav.astro';
import MercantileFooter from '../../components/supermarket/MercantileFooter.astro';
import { products, getPairings } from '../../lib/products';
import type { Product } from '../../lib/products';
import { resolveImage } from '../../lib/images';

export function getStaticPaths() {
  return products.map((product) => ({
    params: { id: product.id },
    props: { product },
  }));
}

interface Props {
  product: Product;
}

const { product } = Astro.props;
const pairings = getPairings(product);

const categoryLabels: Record<string, string> = {
  produce: 'Produce',
  bakery: 'Bakery',
  pantry: 'Pantry',
  'dairy-alt': 'Dairy Alt',
  'juice-bar': 'Tonic Bar',
  'sweet-treats': 'Sweet Treats',
  deli: 'Deli',
};

const categoryLabel = categoryLabels[product.category] ?? product.category;
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
  <meta name="view-transition" content="same-origin" />
  <title>{product.name} — The Mercantile</title>
  <meta name="description" content={product.description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
</head>
<body class="mercantile-page">
  <SensoryNav />

  <main class="pt-[64px]">

    {/* ══ PART 1: Product Detail — Mobile stacked / Desktop split ══ */}
    <div class="product-detail">

      {/* ── Mobile Header (breadcrumbs, title, price, badges) ── */}
      <div class="product-detail-header">
        <nav class="breadcrumbs">
          <a href="/">Home</a>
          <span class="mx-1">/</span>
          <a href={`/#${product.category}`}>{categoryLabel.toUpperCase()}</a>
          <span class="mx-1">/</span>
          <span>{product.name.toUpperCase()}</span>
        </nav>
        <h1 class="product-title">{product.name}</h1>
        <p class="product-price">${product.price.toFixed(2)} <span class="product-price-label">est.</span></p>
        <div class="flex flex-wrap gap-1">
          <span class="badge">{product.label}</span>
          <span class="badge">{product.size}</span>
        </div>
      </div>

      {/* ── Product Image ── */}
      <div class="product-detail-image">
        <div class="product-image-frame">
          <Image
            src={resolveImage(product.image)}
            alt={product.name}
            width={800}
            height={800}
            class="w-full h-full object-cover animate-fade-in"
            loading="eager"
          />
        </div>
      </div>

      {/* ── Product Info (desktop: right column) ── */}
      <div class="product-detail-info">

        {/* Desktop-only breadcrumbs/title/price/badges (hidden on mobile) */}
        <div class="product-info-desktop-meta">
          <nav class="breadcrumbs mb-6">
            <a href="/">Home</a>
            <span class="mx-1">/</span>
            <a href={`/#${product.category}`}>{categoryLabel.toUpperCase()}</a>
            <span class="mx-1">/</span>
            <span>{product.name}</span>
          </nav>
          <h1 class="product-title font-black tracking-tight text-obsidian leading-tight">
            {product.name}
          </h1>
          <p class="product-price font-medium text-obsidian">${product.price.toFixed(2)} <span class="product-price-label text-obsidian-muted font-normal">est.</span></p>
          <div class="flex flex-wrap gap-2 mt-4">
            <span class="badge">{product.label}</span>
            <span class="badge">{product.size}</span>
          </div>
        </div>

        {/* Quantity Selector */}
        <div class="mt-2.5 lg:mt-6">
          <p class="qty-label">Select Amount</p>
          <div class="qty-selector" id="qty-selector">
            <button type="button" id="qty-minus" aria-label="Decrease quantity">&minus;</button>
            <input type="number" class="qty-value" id="qty-value" value="1" min="1" max="100" />
            <button type="button" id="qty-plus" aria-label="Increase quantity">+</button>
          </div>
        </div>

        {/* Add to Bag */}
        <div class="mt-2 lg:mt-4">
          <button
            id="add-to-bag"
            data-product-id={product.id}
            data-product-name={product.name}
            data-product-price={product.price}
            data-product-unit={product.size}
            data-product-image={product.image}
            class="btn-primary w-full py-2 lg:py-3.5 text-[9px] lg:text-[11px] font-bold tracking-[0.02em] text-center"
          >
            + Add to Bag
          </button>
        </div>

        {/* Shopper Notes — hidden on small mobile */}
        <div class="mt-2 lg:mt-4 hidden sm:block">
          <textarea
            id="shopper-notes"
            class="shopper-notes"
            placeholder="Add a note (e.g., 'ripe please', 'slice thin')"
            rows="2"
          ></textarea>
        </div>

        {/* Nutrition Stats */}
        <div class="mt-3 lg:mt-8">
          <div class="macro-grid">
            <div class="text-center">
              <p class="macro-label">Fat</p>
              <p class="macro-value">{product.macros?.fat ?? '—'}</p>
            </div>
            <div class="macro-divider"></div>
            <div class="text-center">
              <p class="macro-label">Carbs</p>
              <p class="macro-value">{product.macros?.carbs ?? '—'}</p>
            </div>
            <div class="macro-divider"></div>
            <div class="text-center">
              <p class="macro-label">Protein</p>
              <p class="macro-value">{product.macros?.protein ?? '—'}</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    {/* Mobile-only: Shopper Notes below the split */}
    <div class="px-4 py-3 bg-bone sm:hidden">
      <textarea
        id="shopper-notes-mobile"
        class="shopper-notes"
        placeholder="Add a note (e.g., 'ripe please', 'slice thin')"
        rows="2"
      ></textarea>
    </div>

    {/* ══ PART 2: Bottom Section — Full Width ══ */}

    {/* Details / Description */}
    <div class="px-6 lg:px-12 py-10 animate-fade-up delay-200">
      <div class="detail-box">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
          <div>
            <p class="text-[10px] font-bold tracking-[0.02em] uppercase text-obsidian-muted mb-1">Origin</p>
            <p class="text-sm text-obsidian leading-[1.7]">{product.origin.region}</p>
          </div>
          <div>
            <p class="text-[10px] font-bold tracking-[0.02em] uppercase text-obsidian-muted mb-1">Altitude / Climate</p>
            <p class="text-sm text-obsidian leading-[1.7]">{product.origin.altitude}</p>
          </div>
        </div>
        <div class="hairline-h my-5"></div>
        <p class="text-[10px] font-bold tracking-[0.02em] uppercase text-obsidian-muted mb-3">Details</p>
        <p class="text-sm text-obsidian leading-[1.7]">{product.description}</p>
      </div>
    </div>

    {/* Pairs Well With — full width */}
    {pairings.length > 0 && (
      <div class="px-6 lg:px-12 pb-10">
        <div class="hairline-h mb-6"></div>
        <h3 class="text-[10px] font-black tracking-[0.02em] uppercase text-obsidian mb-4">Pairs Well With</h3>
        <div class="carousel-wrap">
          <div class="carousel-track" id="carousel-pairings">
            {pairings.map((p, i) => (
              <div class="product-card group stagger-item" style={`animation-delay: ${i * 0.05}s`} data-category={p.category}>
                <a href={`/supermarket/${p.id}`} class="block">
                  <div class="card-image-wrap aspect-square w-full">
                    <Image src={resolveImage(p.image)} alt={p.name} width={800} height={800} class="w-full h-full object-cover product-image" loading="lazy" />
                  </div>
                </a>
                <div class="pt-3">
                  <p class="text-[10px] font-bold tracking-[0.02em] uppercase text-obsidian-muted">{p.label}</p>
                  <h4 class="text-sm font-bold text-obsidian mt-0.5 leading-tight">{p.name}</h4>
                  <div class="flex items-baseline justify-between mt-1">
                    <span class="text-sm font-medium text-obsidian">${p.price.toFixed(2)}</span>
                    <button
                      data-add-pairing
                      data-product-id={p.id}
                      data-product-name={p.name}
                      data-product-price={p.price}
                      data-product-unit={p.size}
                      data-product-image={p.image}
                      class="btn-add"
                    >
                      + Add
                    </button>
                  </div>
                </div>
              </div>
            ))}
          </div>
          <button class="carousel-arrow right" data-scroll-target="carousel-pairings" aria-label="Scroll right">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
          </button>
        </div>
      </div>
    )}

  </main>

  <MercantileFooter />
</body>
</html>

<script>
  import { addToCart, updateNotes } from '../../lib/cartStore';

  function showToast(message: string) {
    const toast = document.getElementById('toast');
    if (!toast) return;
    toast.textContent = message;
    toast.classList.add('visible');
    setTimeout(() => toast.classList.remove('visible'), 2500);
  }

  // Quantity selector
  let qty = 1;
  const qtyInput = document.getElementById('qty-value') as HTMLInputElement;
  document.getElementById('qty-minus')?.addEventListener('click', () => {
    if (qty > 1) {
      qty--;
      qtyInput.value = String(qty);
    }
  });
  document.getElementById('qty-plus')?.addEventListener('click', () => {
    if (qty < 100) {
      qty++;
      qtyInput.value = String(qty);
    }
  });
  qtyInput?.addEventListener('change', () => {
    let val = parseInt(qtyInput.value, 10);
    if (isNaN(val) || val < 1) val = 1;
    if (val > 100) val = 100;
    qty = val;
    qtyInput.value = String(qty);
  });

  // Add to bag
  const notesEl = document.getElementById('shopper-notes') as HTMLTextAreaElement;
  const notesMobileEl = document.getElementById('shopper-notes-mobile') as HTMLTextAreaElement;

  document.getElementById('add-to-bag')?.addEventListener('click', (e) => {
    const btn = e.currentTarget as HTMLElement;
    for (let i = 0; i < qty; i++) {
      addToCart({
        id: btn.dataset.productId!,
        name: btn.dataset.productName!,
        price: parseFloat(btn.dataset.productPrice!),
        unit: btn.dataset.productUnit!,
        image: btn.dataset.productImage!,
      });
    }
    // Save notes if provided (check both desktop and mobile textareas)
    const notes = notesEl?.value.trim() || notesMobileEl?.value.trim();
    if (notes) {
      updateNotes(btn.dataset.productId!, notes);
    }
    showToast(`Added ${qty} to bag`);
  });

  // Pairing add buttons
  document.querySelectorAll('[data-add-pairing]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      addToCart({
        id: el.dataset.productId!,
        name: el.dataset.productName!,
        price: parseFloat(el.dataset.productPrice!),
        unit: el.dataset.productUnit!,
        image: el.dataset.productImage!,
      });
      showToast('Added to bag');
    });
  });

  // Carousel arrow scrolling
  document.querySelectorAll('.carousel-arrow').forEach((arrow) => {
    arrow.addEventListener('click', () => {
      const targetId = (arrow as HTMLElement).dataset.scrollTarget!;
      const track = document.getElementById(targetId);
      if (track) track.scrollBy({ left: 460, behavior: 'smooth' });
    });
  });
</script>
