---
import '../../styles/mercantile.css';
import SensoryNav from '../../components/supermarket/SensoryNav.astro';
import MercantileFooter from '../../components/supermarket/MercantileFooter.astro';
import { products, getPairings } from '../../lib/products';
import type { Product } from '../../lib/products';

export function getStaticPaths() {
  return products.map((product) => ({
    params: { id: product.id },
    props: { product },
  }));
}

interface Props {
  product: Product;
}

const { product } = Astro.props;
const pairings = getPairings(product);

const categoryLabels: Record<string, string> = {
  produce: 'Produce',
  bakery: 'Bakery',
  pantry: 'Pantry',
  'dairy-alt': 'Dairy Alt',
  'juice-bar': 'Tonic Bar',
  'sweet-treats': 'Sweet Treats',
  deli: 'Deli',
};

const categoryLabel = categoryLabels[product.category] ?? product.category;
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="view-transition" content="same-origin" />
  <title>{product.name} — The Mercantile</title>
  <meta name="description" content={product.description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
</head>
<body class="mercantile-page">
  <SensoryNav />

  <main class="pt-[64px]">
    <div class="lg:grid lg:grid-cols-2 lg:min-h-[calc(100vh-64px)]">

      {/* ── LEFT: Square product image on white ── */}
      <div class="relative lg:sticky lg:top-[64px] lg:h-[calc(100vh-64px)] flex items-center justify-center bg-surface p-8 lg:p-12">
        <div class="aspect-square w-full max-w-lg overflow-hidden rounded-[12px]">
          <img
            src={product.image}
            alt={product.name}
            class="w-full h-full object-cover animate-fade-in"
            style={`view-transition-name: product-${product.id}`}
            loading="eager"
          />
        </div>
      </div>

      {/* ── RIGHT: Product info ── */}
      <div class="px-6 lg:px-12 py-8 lg:py-10 lg:overflow-y-auto bg-bone">

        {/* Breadcrumbs */}
        <nav class="breadcrumbs mb-6">
          <a href="/">Home</a>
          <span class="mx-1.5">/</span>
          <a href={`/shop#${product.category}`}>{categoryLabel.toUpperCase()}</a>
          <span class="mx-1.5">/</span>
          <a href={`/shop#${product.category}`}>{product.label}</a>
          <span class="mx-1.5">/</span>
          <span>{product.name}</span>
        </nav>

        {/* Title & Price */}
        <div class="animate-fade-up">
          <h1 class="text-2xl lg:text-3xl font-black tracking-tight text-obsidian leading-tight uppercase">
            {product.name}
          </h1>
          <p class="text-lg font-medium text-obsidian mt-2">${product.price.toFixed(2)} <span class="text-sm text-obsidian-muted font-normal">est.</span></p>

          {/* Badges */}
          <div class="flex gap-2 mt-4">
            <span class="badge">{product.label}</span>
            <span class="badge">{product.size}</span>
          </div>

          {/* Qty Input + Add */}
          <div class="flex items-center gap-4 mt-6">
            <div class="qty-selector" id="detail-qty">
              <button id="qty-minus">-</button>
              <input
                type="number"
                id="qty-input"
                class="qty-input"
                value="1"
                min="1"
                max="99"
              />
              <button id="qty-plus">+</button>
            </div>
            <button
              id="add-to-bag"
              data-product-id={product.id}
              data-product-name={product.name}
              data-product-price={product.price}
              data-product-unit={product.size}
              data-product-image={product.image}
              class="btn-primary flex-1 py-3 text-[11px] font-bold tracking-[0.1em] uppercase text-center"
            >
              Add to Bag
            </button>
          </div>

          {/* Shopper Notes */}
          <div class="mt-4">
            <textarea
              id="shopper-notes"
              class="shopper-notes"
              placeholder="Add a note (e.g., 'ripe please', 'slice thin')"
              rows="2"
            ></textarea>
          </div>
        </div>

        {/* Macro layout */}
        <div class="mt-8 animate-fade-up delay-100">
          <div class="macro-grid">
            <div class="text-center">
              <p class="text-[10px] font-bold tracking-[0.1em] uppercase text-obsidian-muted mb-1">Fat</p>
              <p class="text-lg font-black text-obsidian">{product.macros?.fat ?? '—'}</p>
            </div>
            <div class="macro-divider"></div>
            <div class="text-center">
              <p class="text-[10px] font-bold tracking-[0.1em] uppercase text-obsidian-muted mb-1">Carbs</p>
              <p class="text-lg font-black text-obsidian">{product.macros?.carbs ?? '—'}</p>
            </div>
            <div class="macro-divider"></div>
            <div class="text-center">
              <p class="text-[10px] font-bold tracking-[0.1em] uppercase text-obsidian-muted mb-1">Protein</p>
              <p class="text-lg font-black text-obsidian">{product.macros?.protein ?? '—'}</p>
            </div>
          </div>
        </div>

        <div class="hairline-h my-6"></div>

        {/* Info Section */}
        <div class="animate-fade-up delay-200">
          <div class="py-6 space-y-5">
            <div class="grid grid-cols-1 gap-4">
              <div>
                <p class="text-[10px] font-bold tracking-[0.1em] uppercase text-obsidian-muted mb-1">Origin</p>
                <p class="text-sm text-obsidian">{product.origin.region}</p>
              </div>
              <div>
                <p class="text-[10px] font-bold tracking-[0.1em] uppercase text-obsidian-muted mb-1">Altitude / Climate</p>
                <p class="text-sm text-obsidian">{product.origin.altitude}</p>
              </div>
              <div>
                <p class="text-[10px] font-bold tracking-[0.1em] uppercase text-obsidian-muted mb-1">Harvest</p>
                <p class="text-sm text-obsidian">{product.origin.harvest}</p>
              </div>
            </div>

            {/* Detail box */}
            <div class="detail-box mt-6">
              <p class="text-[10px] font-bold tracking-[0.1em] uppercase text-obsidian-muted mb-3">Details</p>
              <p class="text-sm text-obsidian leading-[1.7]">{product.description}</p>
            </div>
          </div>

          {/* Pairs Well With — horizontal scroll */}
          {pairings.length > 0 && (
            <div class="mt-4">
              <div class="hairline-h mb-6"></div>
              <h3 class="text-[10px] font-black tracking-[0.1em] uppercase text-obsidian mb-4">Pairs Well With</h3>
              <div class="carousel-wrap">
                <div class="carousel-track" id="carousel-pairings">
                  {pairings.map((p, i) => (
                    <div class="product-card group stagger-item" style={`animation-delay: ${i * 0.05}s`} data-category={p.category}>
                      <a href={`/supermarket/${p.id}`} class="block">
                        <div class="card-image-wrap aspect-square w-full">
                          <img src={p.image} alt={p.name} class="w-full h-full object-cover product-image" loading="lazy" />
                        </div>
                      </a>
                      <div class="pt-3">
                        <p class="text-[10px] font-bold tracking-[0.1em] uppercase text-obsidian-muted">{p.label}</p>
                        <h4 class="text-sm font-bold text-obsidian mt-0.5 leading-tight">{p.name}</h4>
                        <div class="flex items-baseline justify-between mt-1">
                          <span class="text-sm font-medium text-obsidian">${p.price.toFixed(2)}</span>
                          <button
                            data-add-pairing
                            data-product-id={p.id}
                            data-product-name={p.name}
                            data-product-price={p.price}
                            data-product-unit={p.size}
                            data-product-image={p.image}
                            class="btn-add"
                          >
                            + Add
                          </button>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
                <button class="carousel-arrow right" data-scroll-target="carousel-pairings" aria-label="Scroll right">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
                </button>
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  </main>

  <MercantileFooter />
</body>
</html>

<script>
  import { addToCart, updateNotes, $cartItems } from '../../lib/cartStore';

  function showToast(message: string) {
    const toast = document.getElementById('toast');
    if (!toast) return;
    toast.textContent = message;
    toast.classList.add('visible');
    setTimeout(() => toast.classList.remove('visible'), 2500);
  }

  // Qty input
  const qtyInput = document.getElementById('qty-input') as HTMLInputElement;

  function getQty(): number {
    const val = parseInt(qtyInput.value, 10);
    return isNaN(val) || val < 1 ? 1 : val;
  }

  document.getElementById('qty-minus')?.addEventListener('click', () => {
    const current = getQty();
    if (current > 1) {
      qtyInput.value = String(current - 1);
    }
  });

  document.getElementById('qty-plus')?.addEventListener('click', () => {
    qtyInput.value = String(getQty() + 1);
  });

  // Clamp on blur
  qtyInput?.addEventListener('blur', () => {
    const val = getQty();
    qtyInput.value = String(val);
  });

  // Add to bag (with qty + notes)
  const notesEl = document.getElementById('shopper-notes') as HTMLTextAreaElement;

  document.getElementById('add-to-bag')?.addEventListener('click', (e) => {
    const btn = e.currentTarget as HTMLElement;
    const qty = getQty();
    for (let i = 0; i < qty; i++) {
      addToCart({
        id: btn.dataset.productId!,
        name: btn.dataset.productName!,
        price: parseFloat(btn.dataset.productPrice!),
        unit: btn.dataset.productUnit!,
        image: btn.dataset.productImage!,
      });
    }
    // Save notes if provided
    const notes = notesEl?.value.trim();
    if (notes) {
      updateNotes(btn.dataset.productId!, notes);
    }
    showToast(`Added ${qty} to bag`);
  });

  // Pairing add buttons
  document.querySelectorAll('[data-add-pairing]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      addToCart({
        id: el.dataset.productId!,
        name: el.dataset.productName!,
        price: parseFloat(el.dataset.productPrice!),
        unit: el.dataset.productUnit!,
        image: el.dataset.productImage!,
      });
      showToast('Added to bag');
    });
  });

  // Carousel arrow scrolling
  document.querySelectorAll('.carousel-arrow').forEach((arrow) => {
    arrow.addEventListener('click', () => {
      const targetId = (arrow as HTMLElement).dataset.scrollTarget!;
      const track = document.getElementById(targetId);
      if (track) track.scrollBy({ left: 460, behavior: 'smooth' });
    });
  });
</script>
