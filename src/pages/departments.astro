---
import '../styles/mercantile.css';
import BaseHead from '../components/BaseHead.astro';
import SensoryNav from '../components/supermarket/SensoryNav.astro';
import MercantileFooter from '../components/supermarket/MercantileFooter.astro';

const departments = [
  { name: 'Produce', slug: 'produce' },
  { name: 'Bakery', slug: 'bakery' },
  { name: 'Deli', slug: 'deli' },
  { name: 'Dairy & Eggs', slug: 'dairy-alt' },
  { name: 'Meat & Seafood', slug: 'meat-seafood' },
  { name: 'Pantry', slug: 'pantry' },
  { name: 'Tonic Bar', slug: 'juice-bar' },
  { name: 'Sweet Treats', slug: 'sweet-treats' },
  { name: 'Frozen', slug: 'frozen' },
  { name: 'Snacks', slug: 'snacks' },
  { name: 'Beverages', slug: 'beverages' },
  { name: 'Wine & Spirits', slug: 'wine-spirits' },
  { name: 'Wellness', slug: 'wellness' },
  { name: 'Home & Body', slug: 'home-body' },
  { name: 'Floral', slug: 'floral' },
];
---

<html lang="en">
<head>
  <BaseHead 
    title="Departments — The Mercantile" 
    description="Browse all departments at The Mercantile."
    enableViewTransitions={true}
    includeGoogleFonts={true}
  />
</head>
<body class="mercantile-page">
  <SensoryNav />

  <main class="main-content pt-[64px]">

    {/* ── 2 Large 2:1 Header Boxes ── */}
    <section class="px-6 lg:px-12 pt-4">
      <div class="max-w-[1200px] mx-auto grid grid-cols-1 md:grid-cols-2 gap-4">
        <a href="/shop?category=bakery" class="relative aspect-[2/1] overflow-hidden rounded-[12px] bg-detail-bg group">
          <div class="w-full h-full bg-detail-bg"></div>
          <div class="absolute inset-0 bg-obsidian/10"></div>
          <div class="absolute bottom-6 left-6">
            <p class="text-[10px] font-bold tracking-[0.1em] uppercase text-obsidian-muted mb-1">Morning Ritual</p>
            <h2 class="text-2xl lg:text-3xl font-black tracking-tight text-obsidian uppercase">Cafe</h2>
          </div>
        </a>
        <a href="/shop?category=juice-bar" class="relative aspect-[2/1] overflow-hidden rounded-[12px] bg-detail-bg group">
          <div class="w-full h-full bg-detail-bg"></div>
          <div class="absolute inset-0 bg-obsidian/10"></div>
          <div class="absolute bottom-6 left-6">
            <p class="text-[10px] font-bold tracking-[0.1em] uppercase text-obsidian-muted mb-1">Cold-Pressed Daily</p>
            <h2 class="text-2xl lg:text-3xl font-black tracking-tight text-obsidian uppercase">Tonic Bar</h2>
          </div>
        </a>
      </div>
    </section>

    {/* ── 5x3 Department Grid ── */}
    <section class="px-6 lg:px-12 py-10">
      <div class="dept-grid">
        {departments.map((dept, i) => (
          <a href={`/shop?category=${dept.slug}`} class="dept-card scroll-reveal" style={`transition-delay: ${i * 0.04}s`}>
            <div class="dept-placeholder"></div>
            <div class="absolute inset-0 flex items-center justify-center p-3">
              <h3 class="text-[10px] lg:text-[11px] font-bold tracking-[0.02em] uppercase text-obsidian text-center" style="font-family: 'Martian Mono', monospace; font-style: normal;">{dept.name}</h3>
            </div>
          </a>
        ))}
      </div>
    </section>

  </main>

  <MercantileFooter />
</body>
</html>

<script>
  // Scroll-reveal animation
  const revealItems = document.querySelectorAll('.scroll-reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('revealed');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  revealItems.forEach((item) => observer.observe(item));
</script>
