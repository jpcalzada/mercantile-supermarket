---
import '../styles/mercantile.css';
import BaseHead from '../components/BaseHead.astro';
import SensoryNav from '../components/supermarket/SensoryNav.astro';
import MercantileFooter from '../components/supermarket/MercantileFooter.astro';
---

<html lang="en">
<head>
  <BaseHead title="Catering — The Mercantile" includeGoogleFonts={true} />
</head>
<body class="mercantile-page">
  <SensoryNav />
  <main class="pt-[64px] px-6 lg:px-12 py-16">
    <h1 class="text-3xl font-black tracking-tight uppercase text-obsidian">Catering</h1>
    <p class="text-obsidian-muted mt-4">Coming soon.</p>
  </main>
  <MercantileFooter />
</body>
</html>
